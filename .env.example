# --- Общие ---
APP_ENV=dev
LOG_LEVEL=INFO

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://finagent:finagent@localhost:5432/finagent

# --- Qdrant (RAG) ---
QDRANT_URL=http://localhost:6333

# --- LLM-провайдер: openai | ollama ---
LLM_PROVIDER=openai

# нужен, если LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# нужен, если LLM_PROVIDER=ollama (запустите: docker compose up -d ollama или локальный ollama serve)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=mistral

# --- Папка с выписками (монтируется в контейнер) ---
STATEMENTS_DIR=./data

# --- MLflow: трассировка вызовов агента (LangGraph/LangChain), полностью локально ---
MLFLOW_TRACKING_URI=sqlite:///./mlflow.db
MLFLOW_EXPERIMENT_NAME=finagent
# смотреть трейсы: uv run mlflow ui --backend-store-uri sqlite:///./mlflow.db

# --- Веб-поиск (опционально) ---
# Единственный инструмент, который уходит за пределы локальной машины — агент вызывает его
# только для внешних фактов (курсы валют, текущие события), никогда с данными пользователя.
# Без ключа просто отключён. Получить ключ: https://tavily.com
TAVILY_API_KEY=
